datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ------------------------------
// Multi-Tenant / Agency Models
// ------------------------------

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  username      String             @unique
  name          String?
  passwordHash  String
  companyName   String?
  emailVerified Boolean            @default(false)
  role          UserRole           @default(USER)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  memberships   WorkspaceMember[]
  verificationTokens EmailVerificationToken[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  ADMIN
}

model Agency {
  id          String      @id @default(cuid())
  name        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspaces  Workspace[]
}

model Workspace {
  id                 String               @id @default(cuid())
  name               String
  domain             String?
  industry           String?
  targetAudience     String?
  toneOfVoice        String?
  agencyId           String?
  onboardingCompleted Boolean              @default(false)
  networkOptIn       Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  agency           Agency?              @relation(fields: [agencyId], references: [id])
  members          WorkspaceMember[]
  contentPlans     ContentPlan[]
  articles         Article[]
  discoveredKeywords DiscoveredKeyword[]
  cmsIntegrations  CMSIntegration[]
  partners        PartnerSite[]
  aiPrompts       AIPrompt[]
  audits          Audit[]
  redditOpps      RedditOpportunity[]
  integrations    Integration[]
}

model Integration {
  id           String    @id @default(cuid())
  workspaceId  String
  provider     String    // "google"
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  accountId    String?   // GA4 Property ID
  accountName  String?   // e.g. "Acme Corp Web Stream"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, provider])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
}

// ------------------------------
// Content Engine
// ------------------------------

model ContentPlan {
  id          String    @id @default(cuid())
  workspaceId String
  month       DateTime
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  articles    Article[]
}

model ArticleTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // e.g. "guide", "listicle"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  articles    Article[]
}

model Article {
  id                String    @id @default(cuid())
  workspaceId       String
  contentPlanId     String?
  articleTemplateId String?
  
  title             String?
  targetKeyword     String
  language          String    @default("en")
  status            String    @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED
  contentJson       Json?
  contentHtml       String?
  url               String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  publishedAt       DateTime?

  workspace         Workspace        @relation(fields: [workspaceId], references: [id])
  contentPlan       ContentPlan?     @relation(fields: [contentPlanId], references: [id])
  template          ArticleTemplate? @relation(fields: [articleTemplateId], references: [id])
  sourceLinks       Backlink[]       @relation("SourceArticle")
  targetLinks       Backlink[]       @relation("TargetArticle")
  sourceLinkOpps    BacklinkOpportunity[] @relation("SourceArticleOpp")
  targetLinkOpps    BacklinkOpportunity[] @relation("TargetArticleOpp")
}

// ------------------------------
// CMS Integrations
// ------------------------------

model CMSIntegration {
  id          String    @id @default(cuid())
  workspaceId String
  type        String    // "WordPress", "Webflow", "Shopify", "Custom"
  credentials Json      // Securely stored in real app
  autoPublish Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

// ------------------------------
// Discover Keywords Tracking
// ------------------------------

model DiscoveredKeyword {
  id               String    @id @default(cuid())
  workspaceId      String
  keyword          String
  monthlyVolume    Int
  difficulty       Int
  opportunityScore Int
  intent           String
  suggestedTitle   String
  category         String
  cpc              Float?
  competitionLevel String?
  dataSource       String?
  niche            String
  websiteUrl       String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace        Workspace @relation(fields: [workspaceId], references: [id])
}

// ------------------------------
// Backlink Exchange Network
// ------------------------------

model PartnerSite {
  id          String    @id @default(cuid())
  workspaceId String
  domain      String    @unique
  niche       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model BacklinkOpportunity {
  id               String   @id @default(cuid())
  sourceArticleId  String
  targetArticleId  String
  proposedAnchor   String
  relevanceScore   Float
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceArticle    Article  @relation("SourceArticleOpp", fields: [sourceArticleId], references: [id])
  targetArticle    Article  @relation("TargetArticleOpp", fields: [targetArticleId], references: [id])
}

model Backlink {
  id               String   @id @default(cuid())
  sourceArticleId  String
  targetArticleId  String
  anchorText       String
  status           String   @default("ACTIVE") // ACTIVE, REMOVED, BROKEN
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceArticle    Article  @relation("SourceArticle", fields: [sourceArticleId], references: [id])
  targetArticle    Article  @relation("TargetArticle", fields: [targetArticleId], references: [id])
}

// ------------------------------
// LLM Visibility Tracking
// ------------------------------

model AIPrompt {
  id              String         @id @default(cuid())
  workspaceId     String
  prompt          String         // e.g. "Best accounting software for startups"
  targetBrand     String         // e.g. "Fynexxa"
  category        String?        // e.g. "Software", "Tools"
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  evaluations     AIEvaluation[] // History of checks

  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AIEvaluation {
  id              String         @id @default(cuid())
  promptId        String
  provider        String         // e.g. "OpenAI", "Anthropic", "Perplexity"
  modelUsed       String         // e.g. "gpt-4o", "claude-3-opus"
  rawResponse     String         @db.Text
  mentionedBrand  Boolean        // True if targetBrand was found in the response
  evaluatedAt     DateTime       @default(now())

  prompt          AIPrompt       @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

// ------------------------------
// Technical SEO Audit
// ------------------------------

model Audit {
  id          String    @id @default(cuid())
  workspaceId String
  type        String    @default("Technical")
  status      String    @default("PENDING") // PENDING, COMPLETED
  summaryScore Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  issues      AuditIssue[]
}

model AuditIssue {
  id          String    @id @default(cuid())
  auditId     String
  url         String
  type        String    // e.g. "missingTitle", "slowResponse"
  severity    String    // "HIGH", "MEDIUM", "LOW"
  description String?
  createdAt   DateTime  @default(now())

  audit       Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

// ------------------------------
// Reddit AI Agent
// ------------------------------

model RedditOpportunity {
  id             String    @id @default(cuid())
  workspaceId    String
  subreddit      String
  threadUrl      String
  title          String
  snippet        String?   @db.Text
  relevanceScore Float
  status         String    @default("NEW") // NEW, DONE, IGNORED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id])
}
